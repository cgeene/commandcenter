{
  "name": "commandcenter",
  "version": "0.1.0",
  "description": "Personal agent platform: task queue + Claude Code worker orchestration over tmux",
  "private": true,
  "type": "module",
  "bin": {
    "agentd": "./dist/daemon/index.js",
    "agp": "./dist/cli/index.js",
    "cc-mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:daemon": "tsx src/daemon/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:web": "npm --prefix web run build",
    "build:all": "npm run build && npm run build:web",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.2.0",
    "commander": "^14.0.0",
    "croner": "^10.0.1",
    "hono": "^4.8.0",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
